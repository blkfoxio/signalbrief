# DeHashed API
DEHASHED_API=your-dehashed-api-key

# OpenAI
OPENAI_API=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Microsoft Azure AD (OAuth)
MS_AZURE_CLIENT_ID=your-azure-client-id
MS_AZURE_SECRET=your-azure-client-secret
MS_AZURE_TENANT_ID=common
MS_AZURE_REDIRECT_URI=http://localhost:5173/auth/callback

# Proxycurl (LinkedIn enrichment)
PROXYCURL_API=your-proxycurl-api-key

# Railway
RAILWAY_PROJECT_ID=

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:5173
DJANGO_SETTINGS_MODULE=signalbrief.settings.development

# Database (auto-injected by Railway in production)
DATABASE_URL=sqlite:///db.sqlite3
